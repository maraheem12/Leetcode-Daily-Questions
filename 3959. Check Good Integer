class Solution {
    public boolean checkGoodInteger(int n) {
        int squareSum = 0;
        int digitSum = 0;
        while(n > 0){
            int temp = n%10;
            n = n/10;
            squareSum += (temp*temp);
            digitSum += temp;
        }
        return (squareSum - digitSum) >= 50;
    }
}
