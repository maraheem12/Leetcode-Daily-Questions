/**
 * Definition for a binary tree node.
 * public class TreeNode {
 *     int val;
 *     TreeNode left;
 *     TreeNode right;
 *     TreeNode() {}
 *     TreeNode(int val) { this.val = val; }
 *     TreeNode(int val, TreeNode left, TreeNode right) {
 *         this.val = val;
 *         this.left = left;
 *         this.right = right;
 *     }
 * }
 */
class Solution {
    public TreeNode createBinaryTree(int[][] descriptions) {
        HashSet<Integer> parentSet = new HashSet<>();
        HashMap<Integer ,TreeNode> map = new HashMap<>();
        int n = descriptions.length;
        for(int i=0; i<n; i++){
            TreeNode root = null;
            if(map.containsKey(descriptions[i][0])){
                root = map.get(descriptions[i][0]);
            }
            else{
                root = new TreeNode(descriptions[i][0]);
                map.put(descriptions[i][0], root);
            }
            if(descriptions[i][2] == 1){
                if(map.containsKey(descriptions[i][1])){
                    root.left = map.get(descriptions[i][1]);
                }
                else{
                    map.put(descriptions[i][1], new TreeNode(descriptions[i][1]));
                    root.left = map.get(descriptions[i][1]);
                }
            }
            else{
                if(map.containsKey(descriptions[i][1])){
                    root.right = map.get(descriptions[i][1]);
                }
                else{
                    map.put(descriptions[i][1], new TreeNode(descriptions[i][1]));
                    root.right = map.get(descriptions[i][1]);
                }
            }
        }
        for(int i=0; i<n; i++){
           map.remove(descriptions[i][1]); 
        }
        for(int i: map.keySet()){
           return map.get(i);
        }
        return new TreeNode(0);
    }
}
