class Solution {

    Boolean[] dp;
    int farthest = 0;

    public boolean dfs(int i, String s, int minJump, int maxJump) {

        int n = s.length();

        if(i == n - 1) {
            return true;
        }

        if(dp[i] != null) {
            return dp[i];
        }

        int start = Math.max(i + minJump, farthest);
        int end = Math.min(i + maxJump, n - 1);

        for(int j = start; j <= end; j++) {

            if(s.charAt(j) == '0') {

                if(dfs(j, s, minJump, maxJump)) {
                    return dp[i] = true;
                }
            }
        }

        farthest = Math.max(farthest, end + 1);

        return dp[i] = false;
    }

    public boolean canReach(String s, int minJump, int maxJump) {

        int n = s.length();

        if(s.charAt(n - 1) != '0') {
            return false;
        }

        dp = new Boolean[n];

        return dfs(0, s, minJump, maxJump);
    }
}
