class Solution {
    public int binaryGap(int n) {
        int max=0;
        String bits = Integer.toBinaryString(n);
        int len = bits.length();
        //int bits = Integer.parseInt(s);
        
        for(int i=0; i<len; i++){
            if(bits.charAt(i) == '1'){
                for(int j=i+1; j<len; j++){
                    if(bits.charAt(j) == '1'){
                        max = Math.max(max, j-i);
                        break;
                    }
                }
            }
        }
        return max;
    }
}
