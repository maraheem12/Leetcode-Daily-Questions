class Solution {
    public int countDigitOccurrences(int[] nums, int digit) {
        StringBuilder num = new StringBuilder();
        int n = nums.length;
        for(int i=0; i<n; i++){
            num.append(nums[i]);
        }
        // char d = (char)digit;
        int count=0;
        String u = num.toString();
        for(char c: u.toCharArray()){
            if(c-'0' == digit){
                count++;
            }
            //System.out.println(c);
        }
        return count;
    }
}
