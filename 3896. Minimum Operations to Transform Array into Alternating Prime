class Solution {
    static boolean isPrime(int n) {
        if (n <= 1) return false;
        if(n == 2 || n==3) return true;
        if (n % 2 == 0 || n % 3 == 0) return false;
        for (int i = 5; i * i <= n; i += 2)
            if (n % i == 0) return false;
        return true;
    }

    static int nextPrime(int n) {
        while (!isPrime(n)) n++;
        return n;
    }
    static int nextNotPrime(int n) {
        while (isPrime(n)) n++;
        return n;
    }
    public int minOperations(int[] nums) {
        int n = nums.length;
        int count=0;
        for(int i=0; i<n; i++){
            if(i%2 == 0){
                count += (nextPrime(nums[i]) - nums[i]);
            }
            else{
                count += (nextNotPrime(nums[i]) - nums[i]);
            }
        }
        return count;
    }
}


