class Solution {
    public int minimumCost(int[] cost) {
        int n = cost.length;
        int buy = 0;
        Arrays.sort(cost);
        int jump = 0;
        for(int i=n-1; i>=0; i--){
            if(jump < 2){
                buy += cost[i];
                jump++;
            }
            else{
                jump = 0;
            }
        }
        return buy;
    }
}
