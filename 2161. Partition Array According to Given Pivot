class Solution {
    public int[] pivotArray(int[] nums, int pivot) {
        int small[]=new int[nums.length];
        int big[]=new int[nums.length];
        int eq[]=new int[nums.length];
        int s=0;
        int b=0;
        int e=0;
        for(int i=0;i<nums.length;i++){
            if(nums[i]<pivot){
                small[s]=nums[i];
                s++;
            }else if(nums[i]>pivot){
                big[b]=nums[i];
                b++;
            }else if(pivot==nums[i]){
                eq[e]=nums[i];
                e++;
            }
        }
        int j=0;
        for(int i=0;i<s;i++){
            nums[j]=small[i];
            j++;
        }
        
        for(int i=0;i<e;i++){
            nums[j]=eq[i];
            j++;
        }
        System.out.print(j);
        for(int i=0;i<b;i++){
            nums[j]=big[i];
            j++;
        }
        return nums;
    }
}
