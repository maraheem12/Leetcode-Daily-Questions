class Solution {
    public int maxIceCream(int[] costs, int coins) {
        int n = costs.length;
        int buy = 0;
        Arrays.sort(costs);
        for(int i=0; i<n; i++){
            if(costs[i] <= coins){
                coins = coins - costs[i];
                buy++;
            }
            else{
                break;
            }
        }
        return buy;
    }
}
