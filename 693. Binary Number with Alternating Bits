class Solution {
    public boolean check(String n){
        int m = n.length();
        for(int i=0; i<m-1; i++){
            if(n.charAt(i) == n.charAt(i+1)){
                return false;
            }
        }
        return true;
    }
    public boolean hasAlternatingBits(int n) {
        String bits = Integer.toBinaryString(n);
        return check(bits);
    }
}
