class Solution {
    public int[] countOppositeParity(int[] nums) {
        int n = nums.length;
        int ans[] = new int[n];
        for(int i=0; i<n; i++){
            boolean even = false;
            int count=0;
            if(nums[i]%2 == 0){
                even = true;
            }
            if(even){
                for(int j=i+1; j<n; j++){
                    if(nums[j]%2 != 0){
                        count++;
                    }
                }
            }
            else{
                for(int j=i+1; j<n; j++){
                    if(nums[j]%2 == 0){
                        count++;
                    }
                }
            }
            ans[i] = count;
        }
        return ans;
    }
}
