class Solution {
    public boolean valid(StringBuilder str, int k){
        String s = str.toString();
        int n = s.length();
        int sum=0;
        for(int i=1; i<n; i++){
            if(s.charAt(i) == '1'){
                sum += i;
                if(s.charAt(i-1) == '1') return false;
            }
        }
        return (sum <= k)? true: false;
    }
    public void fun(int n, int k, int idx, StringBuilder curr, List<String> res){
        if(idx == n){
            if(valid(curr, k)){
                res.add(curr.toString());
            } 
            return;
        }
        curr.append(0);
        fun(n, k, idx+1, curr, res);
        curr.deleteCharAt(curr.length()-1);
        curr.append(1);
        fun(n, k, idx+1, curr, res);
        curr.deleteCharAt(curr.length()-1);
        return;
    }
    public List<String> generateValidStrings(int n, int k) {
        List<String> res = new ArrayList<>();
        fun(n, k, 0, new StringBuilder(), res);
        return res;
    }
} 
