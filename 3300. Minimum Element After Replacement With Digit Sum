class Solution {
    public int check(int n){
        int sum = 0;
        while(n > 0){
            sum += (n%10);
            n = n/10;
        }
        return sum;
    }
    public int minElement(int[] nums) {
        int min = Integer.MAX_VALUE;
        int n = nums.length;
        for(int i=0; i<n; i++){
            min = Math.min(min, check(nums[i]));
        }
        return min;
    }
}
